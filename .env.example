# PostgreSQL
POSTGRES_USER=dataforge
POSTGRES_PASSWORD=dataforge
POSTGRES_DB=dataforge
POSTGRES_PORT=5432

# Backend
APP_NAME=DataForge
APP_ENV=production
LOG_LEVEL=INFO
BACKEND_PORT=8000
MAX_UPLOAD_SIZE_MB=100
CORS_ORIGINS=["http://localhost:8501","http://localhost:8000"]

# Dashboard
DASHBOARD_PORT=8501
DATAFORGE_API_TIMEOUT=120
