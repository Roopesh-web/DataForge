# Example nginx config for serving the Vite production build (frontend/dist)
# and optionally reverse-proxying the DataForge API on the same host.
#
# Adjust server_name, root, and proxy_pass for your environment.
# When API is proxied on the same origin, leave VITE_API_URL empty at build time.
# When API is on a separate host, build with:
#   VITE_API_URL=https://api.example.com npm run build

server {
  listen 80;
  server_name app.example.com;
  root /var/www/dataforge/dist;
  index index.html;

  # SPA client-side routing (React Router BrowserRouter)
  location / {
    try_files $uri $uri/ /index.html;
  }

  # Optional: same-origin API proxy (requires empty VITE_API_URL at build time)
  location ~ ^/(health|openapi\.json|upload|profile|analytics|quality-check|warehouse)(/|$) {
    proxy_pass http://127.0.0.1:8000;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    client_max_body_size 100M;
  }

  location ~* \.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?)$ {
    expires 7d;
    add_header Cache-Control "public, immutable";
  }
}
