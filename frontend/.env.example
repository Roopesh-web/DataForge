# DataForge Frontend — environment variables
#
# Copy to `.env` or `.env.production.local` as needed.
# Only variables prefixed with VITE_ are exposed to the browser bundle.

# -----------------------------------------------------------------------------
# VITE_API_URL (required for separate API host in production)
# -----------------------------------------------------------------------------
# Absolute base URL of the DataForge FastAPI backend (no trailing slash).
#
# Local Vite development:
#   Leave empty so requests stay same-origin and use the Vite proxy.
#
# Production (API on another origin):
#   VITE_API_URL=https://api.example.com
#
# Production (nginx reverse-proxies API on the same origin):
#   Leave empty (same-origin relative requests).
#
VITE_API_URL=

# -----------------------------------------------------------------------------
# VITE_BASE (optional)
# -----------------------------------------------------------------------------
# Public path when the app is served from a subdirectory.
# Must start and end with `/` (Vite convention). Default: /
# Example: VITE_BASE=/dataforge/
# VITE_BASE=/

# -----------------------------------------------------------------------------
# VITE_DEV_PROXY_TARGET (development only — not used in production builds)
# -----------------------------------------------------------------------------
# Backend URL for the Vite dev-server proxy. Default: http://localhost:8000
# VITE_DEV_PROXY_TARGET=http://localhost:8000
